---
import { Image } from 'astro:assets';
import kojiImg from '@src/assets/img/koji.png';

type PicSize = 'sm' | 'md' | 'lg';
interface Props {
	picSize: PicSize;
}
const { picSize } = Astro.props;
---

<div class='flex gap-4 items-center leading-tight not-prose'>
	<a
		href='https://github.com/koji'
		target='_blank'
		rel='noopener noreferrer'
		class:list={[
			'rounded-full overflow-hidden shrink-0 shadow-apple',
			{ 'w-12 h-12': picSize === 'sm' },
			{ 'w-[70px] h-[70px]': picSize === 'md' },
			{ 'w-[90px] h-[90px]': picSize === 'lg' }
		]}
	>
		<Image src={kojiImg} alt='koji' />
	</a>
	<div>
		<div>
			<a
				href='https://github.com/koji/blog'
				class='block font-semibold text-apple-near-black dark:text-white hover:text-apple-link-blue dark:hover:text-apple-bright-blue transition-colors'
				target='_blank'
				rel='noopener noreferrer'
			>
				koji
			</a>
		</div>
		<small class='text-black/48 dark:text-white/48 tracking-[-0.224px]'>Software Engineer</small>
	</div>
</div>
